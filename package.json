{
  "name": "run-mcp",
  "version": "1.7.4",
  "description": "A smart proxy and interactive REPL for Model Context Protocol (MCP) servers",
  "homepage": "https://github.com/funkyfunc/run-mcp#readme",
  "bugs": {
    "url": "https://github.com/funkyfunc/run-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/funkyfunc/run-mcp.git"
  },
  "license": "ISC",
  "author": "funkyfunc",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proxy",
    "repl",
    "cli"
  ],
  "bin": {
    "run-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup && node scripts/update-readme-help.js",
    "build:fixtures": "tsup tests/fixtures/mock-server.ts tests/fixtures/vulnerable-stdio-server.ts --format esm --target node18 --out-dir tests/fixtures/dist",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"tests/**/*.{ts,js,json}\" \"*.{ts,js,json}\"",
    "pretest": "tsup && npm run build:fixtures",
    "test": "vitest run",
    "update-schema": "node scripts/update-schema.js",
    "prepublishOnly": "tsup",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "tree-kill": "^1.2.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.14",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.1",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run format && npm run lint && npm run typecheck && npm test"
  }
}
