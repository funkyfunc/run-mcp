{
  "name": "run-mcp",
  "version": "1.4.0",
  "description": "A smart proxy and interactive REPL for Model Context Protocol (MCP) servers",
  "homepage": "https://github.com/funkyfunc/run-mcp#readme",
  "bugs": {
    "url": "https://github.com/funkyfunc/run-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/funkyfunc/run-mcp.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proxy",
    "repl",
    "cli"
  ],
  "bin": {
    "run-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "pretest": "tsup",
    "test": "vitest run",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.13.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
